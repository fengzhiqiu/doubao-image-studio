{
  "manifest_version": 3,
  "name": "豆包生图助手",
  "version": "1.0.0",
  "description": "豆包 AI 生图自动化助手",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://www.doubao.com/*"
  ],
  "background": {
    "service_worker": "assets/background.ts.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts.js"
      ],
      "matches": [
        "https://www.doubao.com/*"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.doubao.com/*"
      ],
      "resources": [
        "assets/hook.js",
        "assets/index.ts.js"
      ],
      "use_dynamic_url": false
    }
  ]
}